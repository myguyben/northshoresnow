---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

const logoModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/logos/*.{png,jpg,webp}',
  { eager: true }
)
const logos = Object.entries(logoModules)
  .map(([path, mod]) => ({
    image: mod.default,
    alt: (path.split('/').pop() ?? '')
      .replace(/\.(png|jpg|webp)$/, '')
      .replace(/-/g, ' ')
      .replace(/\b\w/g, (c) => c.toUpperCase()),
  }))
  .sort((a, b) => a.alt.localeCompare(b.alt))
---

<section class="border-y border-frost-100 bg-white py-10">
  <div class="container-site">
    <p class="text-center text-[13px] font-semibold tracking-[0.14em] text-body/80 uppercase">
      Trusted by leading businesses &amp; property managers
    </p>
  </div>
  <div class="mt-7 overflow-hidden" aria-hidden="false">
    <div class="animate-marquee flex w-max items-center gap-14 px-7 motion-reduce:w-full motion-reduce:flex-wrap motion-reduce:justify-center">
      {[0, 1].map((copy) => (
        <div
          class:list={[
            'flex items-center gap-14',
            copy === 1 ? 'motion-reduce:hidden' : '',
          ]}
          aria-hidden={copy === 1 ? 'true' : undefined}
        >
          {logos.map((logo) => (
            <Image
              src={logo.image}
              alt={copy === 0 ? logo.alt : ''}
              height={40}
              class="h-9 w-auto opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0"
              loading="lazy"
            />
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
