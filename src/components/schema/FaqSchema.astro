---
interface Props {
  faqs: Array<{ q: string; a: string }>
}

const { faqs } = Astro.props

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
}
---

{faqs.length > 0 && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
