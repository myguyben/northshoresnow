---
import { SITE } from '../lib/site'

/**
 * Single-step quote form: work email + property address + scope of the site.
 * The AI quoting pipeline measures the property from satellite imagery, so
 * the address is the field that matters most — it autocompletes via the
 * Icey address-autocomplete proxy (Google Places under the hood). The scope
 * description feeds the pipeline's scope prompt (which areas get outlined
 * and quoted). Submits JSON to the Icey website-lead endpoint; on failure
 * it degrades to a prefilled mailto (which feeds the same intake via email).
 */
---

<div class="card p-6 md:p-8" id="quote">
  <div class="mb-6">
    <h3 class="font-display text-2xl font-bold">Get your free quote</h3>
    <p class="mt-1.5 text-[15px] text-body">
      Satellite-measured, no site visit needed. Most quotes are ready the same day.
    </p>
  </div>

  <form id="quote-form" novalidate>
    <div class="space-y-5">
      <div>
        <label class="label" for="qf-email">Work email *</label>
        <input
          class="input"
          id="qf-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="you@company.com"
        />
      </div>

      <div>
        <label class="label" for="qf-address">Commercial property address *</label>
        <div class="relative" data-address-autocomplete>
          <input
            class="input"
            id="qf-address"
            name="address"
            type="text"
            required
            minlength="5"
            autocomplete="off"
            role="combobox"
            aria-expanded="false"
            aria-controls="qf-address-listbox"
            aria-autocomplete="list"
            placeholder="Start typing the address…"
          />
          <ul
            class="address-listbox"
            id="qf-address-listbox"
            role="listbox"
            aria-label="Address suggestions"
            hidden
          ></ul>
        </div>
      </div>

      <div>
        <label class="label" for="qf-scope">Scope of the site *</label>
        <p class="mb-2 -mt-0.5 text-sm text-body/80">
          Describe what we should take care of — we'll outline exactly those areas on
          satellite imagery.
        </p>
        <textarea
          class="input"
          id="qf-scope"
          name="scope"
          rows="3"
          required
          minlength="10"
          maxlength="2000"
          placeholder="e.g. Clear and salt the main parking lot, both entrances and the sidewalks around the building…"></textarea>
      </div>

      <!-- Honeypot: humans never see or fill this. -->
      <div class="absolute -left-[9999px] h-0 w-0 overflow-hidden" aria-hidden="true">
        <label for="qf-website">Website</label>
        <input id="qf-website" name="website" type="text" tabindex="-1" autocomplete="off" />
      </div>
    </div>

    <div id="qf-error" hidden class="mt-5 rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-800">
      <p class="font-semibold">We couldn't send your request automatically.</p>
      <p class="mt-1">
        Email us instead — one click, your details are already filled in:
        <a id="qf-mailto" class="font-semibold underline" href={`mailto:${SITE.email}`}>
          {SITE.email}
        </a>
        or call
        <a class="font-semibold underline" href={SITE.phoneHref}>{SITE.phone}</a>.
      </p>
    </div>

    <div class="mt-6 flex items-center justify-between gap-4">
      <p class="text-[13px] leading-relaxed text-body/80">
        By requesting a quote you agree to be contacted about your property. We never share
        your details.
      </p>
      <button type="submit" id="qf-submit" class="btn-primary shrink-0 !px-8">
        <svg
          id="qf-spinner"
          class="h-4 w-4 animate-spin"
          viewBox="0 0 24 24"
          fill="none"
          hidden
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25"></circle>
          <path fill="currentColor" class="opacity-90" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
        </svg>
        Get my quote
      </button>
    </div>
  </form>
</div>

<script>
  import { setupQuoteForm } from '../scripts/quote-form'
  setupQuoteForm()
</script>
