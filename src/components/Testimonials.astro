---
/**
 * Real Google reviews, quoted verbatim from our Google Business Profile
 * (5.0, 26 reviews). Only reviews that don't reference the Maintenance
 * Masters name or summer services are shown here. Update the count/link
 * together if the listing changes.
 */

const GOOGLE_REVIEWS_URL =
  'https://www.google.com/maps/place/?q=place_id:ChIJWQ-g9MNEf2oRhmrru26SGtc'
const REVIEW_COUNT = 26

const reviews = [
  {
    quote:
      'We collaborate with Luke and his team last winter on snow removal and salting projects, and everything was always handled with courtesy and professionalism. Highly recommending their services!',
    name: "Matt's home services",
  },
  {
    quote:
      'Jay, Luke and the team were great to deal with. They were polite and had great attention to detail, and even provided before and after pics. Luke even offered to come by after the weekend in case they missed anything. Great service!',
    name: 'Sara',
  },
  {
    quote:
      'These guys did a great job for me for a reasonable price. Kaveh and Steven were professional, courteous, and hard working. They stayed onsite from 9 in the am to 7 pm. I would definitely recommend them.',
    name: 'Sina K',
  },
  {
    quote:
      'Professional service at a very reasonable price. Customer service and communication was on point!',
    name: 'Stim Citizen',
  },
  {
    quote: 'Great guys! Fast service and the work is top rate. See you in the fall.',
    name: 'Susanne Mackillop',
  },
  {
    quote: 'Highly recommend, reasonably priced, hard working & did a fabulous job',
    name: 'vanda Sullivan',
  },
]
---

<section class="section bg-frost-50">
  <div class="container-site">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="eyebrow">What clients say</p>
        <h2 class="h2 mt-2 max-w-xl">Trusted through every storm</h2>
        <p class="mt-3 max-w-2xl text-[15px] text-body">
          Real reviews from our Google Business Profile.
        </p>
      </div>
      <a
        href={GOOGLE_REVIEWS_URL}
        target="_blank"
        rel="noopener"
        class="group flex items-center gap-3 rounded-2xl border border-frost-200 bg-white px-5 py-3.5 shadow-card transition-colors hover:border-brand-500"
      >
        <span class="font-display text-3xl font-bold text-ink-950">5.0</span>
        <span>
          <span class="flex gap-0.5" aria-label="Rated 5 out of 5 stars">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="h-4 w-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 14.9l-5.2 2.7 1-5.8-4.3-4.1 5.9-.9L10 1.5z" />
              </svg>
            ))}
          </span>
          <span class="mt-0.5 block text-sm text-body group-hover:text-brand-600">
            {REVIEW_COUNT} Google reviews →
          </span>
        </span>
      </a>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {reviews.map((review) => (
        <figure class="card flex flex-col p-7">
          <span class="flex gap-0.5" aria-label="5 out of 5 stars">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="h-4 w-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 14.9l-5.2 2.7 1-5.8-4.3-4.1 5.9-.9L10 1.5z" />
              </svg>
            ))}
          </span>
          <blockquote class="mt-4 flex-1 text-[15px] leading-relaxed text-ink-900">
            “{review.quote}”
          </blockquote>
          <figcaption class="mt-5 flex items-center justify-between text-sm">
            <span class="font-semibold text-body">{review.name}</span>
            <span class="text-body/70">Google review</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
