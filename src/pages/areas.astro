---
import { getCollection } from 'astro:content'
import Base from '../layouts/Base.astro'
import HeroPage from '../components/HeroPage.astro'
import CtaBand from '../components/CtaBand.astro'
import Testimonials from '../components/Testimonials.astro'

const areas = await getCollection('areas')
const order = [
  'north-vancouver',
  'west-vancouver',
  'downtown-vancouver',
  'north-shore',
  'lonsdale',
  'lynn-valley',
  'edgemont-village',
  'deep-cove',
  'capilano',
  'seymour',
  'ambleside',
  'dundarave',
  'horseshoe-bay',
]
const sorted = [...areas].sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id))
---

<Base
  title="Snow Removal Service Areas | North Shore Snow"
  description="Commercial snow removal across North Vancouver, West Vancouver, Downtown Vancouver and every North Shore neighborhood — Lonsdale to Horseshoe Bay. Call (604) 990-7072."
>
  <HeroPage
    eyebrow="Service areas"
    heading="Local crews across the North Shore & Vancouver"
    lede="Our routes are built around the North Shore's geography — sea-level retail strips to mountain-side strata at 300 m elevation. Pick your area to see how we work there."
    trail={[{ name: 'Areas', path: '/areas' }]}
  />

  <section class="section">
    <div class="container-site">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {sorted.map((area) => (
          <a href={`/${area.id}`} class="card card-hover group block p-7">
            <h2 class="font-display text-xl font-bold group-hover:text-brand-600">
              {area.data.name}
            </h2>
            <p class="mt-3 text-[15px] leading-relaxed">{area.data.description}</p>
            <p class="mt-4 text-sm text-body/80">
              {area.data.neighborhoods.slice(0, 4).join(' · ')}
            </p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600">
              Snow removal in {area.data.name}
              <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8h10M9 4l4 4-4 4" />
              </svg>
            </span>
          </a>
        ))}
      </div>
      <p class="mt-10 text-[15px]">
        Want response-time details and coverage maps? See the full
        <a href="/service-areas" class="font-semibold text-brand-600 hover:underline">service area breakdown</a>.
      </p>
    </div>
  </section>

  <Testimonials />
  <CtaBand />
</Base>
